{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amazon-ec2-auto-scaling/refs/heads/main/json-schema/ec2-auto-scaling-processes-type-schema.json",
  "title": "ProcessesType",
  "description": "ProcessesType schema from Auto Scaling",
  "type": "object",
  "properties": {
    "Processes": {
      "allOf": [
        {
          "$ref": "#/components/schemas/Processes"
        },
        {
          "description": "The names of the process types."
        }
      ]
    }
  },
  "example": {
    "Processes": [
      {
        "ProcessName": "AZRebalance"
      },
      {
        "ProcessName": "AddToLoadBalancer"
      },
      {
        "ProcessName": "AlarmNotification"
      },
      {
        "ProcessName": "HealthCheck"
      },
      {
        "ProcessName": "Launch"
      },
      {
        "ProcessName": "ReplaceUnhealthy"
      },
      {
        "ProcessName": "ScheduledActions"
      },
      {
        "ProcessName": "Terminate"
      }
    ]
  }
}